# ---------------------------------------------------------------------------
# Renew — environment variables
# Copy this file to ".env" and fill in the values from your Supabase project.
# Find them in Supabase: Project Settings -> API.
#
# Only these two keys are needed. The compliance acceptance log and the product
# catalog both use the public "anon" key with row-level security, so no secret
# service_role key is required (and it must NEVER be placed in a Vite frontend,
# since anything with the VITE_ prefix ships to the browser).
#
# The app runs on bundled local data if these are left blank, so you can
# develop the frontend before wiring up Supabase.
# ---------------------------------------------------------------------------

# Your project URL, e.g. https://abcdefghijklmno.supabase.co
VITE_SUPABASE_URL=

# Your project's public anon/publishable key (safe to expose in the browser)
VITE_SUPABASE_ANON_KEY=
